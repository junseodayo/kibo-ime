<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 앱별 기본 언어(§11): 현재 포커스된 앱의 패키지명은 EditorInfo.packageName으로 얻으므로
         별도 패키지 질의 권한은 필요 없음. 설정 화면에서 설치된 앱 목록을 보여주려면 아래 query 사용. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kibo.Settings">

        <!-- IME 본체 (§1). InputMethodService 기반. -->
        <service
            android:name=".KiboInputMethodService"
            android:label="@string/ime_label"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- 설정 화면 (§2, §11, §13 등). 시스템 키보드 설정에서 '설정' 진입점으로도 사용. -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:label="@string/settings_title"
            android:exported="true"
            android:theme="@style/Theme.Kibo.Settings">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
